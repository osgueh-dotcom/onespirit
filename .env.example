# Application Ports
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Runtime Environment
ENV=development
DEBUG=false
AUTO_CREATE_TABLES=true
SEED_DEMO_USER=true
SEED_PLACEHOLDER_USERS=true

# Security Settings
# Gunakan nilai rahasia kuat di environment lokal/production. Jangan commit secret asli.
JWT_SECRET=change-me-use-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# PostgreSQL Database Configuration
DB_HOST=db
DB_PORT=5432
DB_PORT_HOST=5433
DB_USER=onespirit_user
DB_PASSWORD=change-me-db-password
DB_NAME=onespirit_db

# BACKEND_CORS_ORIGINS digunakan backend FastAPI untuk mengizinkan frontend lokal dan GitHub Pages.
# Origin CORS tidak memakai path /onespirit/.
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","https://osgueh-dotcom.github.io"]

# VITE_API_BASE_URL digunakan untuk frontend build/GitHub Pages.
# Untuk production/demo frontend, lebih rapi gunakan frontend/.env.production.example.
VITE_API_BASE_URL=https://your-backend-demo-tunnel-url

# File Upload Settings
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# Seeding Credentials
# Isi dengan credential development/demo lokal. Jangan gunakan password default atau password asli di repository.
ADMIN_EMAIL=admin@onespirit.asia
ADMIN_PASSWORD=change-me-admin-password
DEMO_EMAIL=demo@onespirit.asia
DEMO_PASSWORD=change-me-demo-password
DEMO_USER_EMAIL=demo@onespirit.asia
DEMO_USER_PASSWORD=change_me_for_demo_only
# Demo password wajib diganti sebelum public demo.
# Jangan gunakan password ini untuk production.
